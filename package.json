{
  "name": "touring-crew-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx nodemon",
    "dev:simple": "prisma generate && next dev -p 3000",
    "dev:clean": "npm run dev:kill && rm -rf .next && npm run dev",
    "dev:kill": "lsof -ti:3000 2>/dev/null | xargs kill -9 2>/dev/null; lsof -ti:3001 2>/dev/null | xargs kill -9 2>/dev/null; lsof -ti:8080 2>/dev/null | xargs kill -9 2>/dev/null; echo Ports cleared",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "verify": "tsc --noEmit && eslint . && next build --webpack",
    "check": "tsc --noEmit && eslint .",
    "db:generate": "prisma generate",
    "db:push": "dotenv -o -e .env -e .env.local -- prisma db push",
    "db:migrate:deploy": "dotenv -o -e .env -e .env.local -- prisma migrate deploy",
    "db:seed": "dotenv -o -e .env -e .env.local -- tsx prisma/seed.ts",
    "db:clear-people": "node prisma/clear-people.cjs",
    "db:assign-marius-pm": "node prisma/assign-marius-productionmanager.cjs",
    "db:migrate-projects": "node prisma/migrate-to-projects.cjs",
    "db:import-sqlite": "tsx scripts/import-sqlite-to-neon.ts",
    "stitch:fetch": "node scripts/fetch-stitch-screen.mjs",
    "db:set-password": "node scripts/set-supabase-user-password.mjs",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/client": "6.19.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "city-timezones": "^1.2.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "prisma": "6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@google/stitch-sdk": "^0.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.8.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": "bash -c 'npm run check'"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4",
    "effect": "^3.20.0"
  }
}
