# --- Database (required) — Supabase Postgres + Prisma ---
#
# Supabase: Project Settings → Database → Connection string
#   - DATABASE_URL: Transaction pooler (port 6543) + ?pgbouncer=true&sslmode=require
#   - DIRECT_URL: Session pooler (port 5432) + ?sslmode=require
#   (IPv4 networks need pooler URLs; direct db.*.supabase.co may be IPv6-only.)
#
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Optional: log every SQL in dev (slow; default is off — errors/warnings only)
# PRISMA_LOG_QUERIES=1

# --- Supabase Auth (required) ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ...anon..."
# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."

# Optional: show Google sign-in button (configure provider in Supabase Dashboard first)
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="1"

# Optional: app name in UI (defaults to "Tour Me Like It's Hot")
# NEXT_PUBLIC_APP_NAME="Tour Me Like It's Hot"

# PWA (service worker + install): on for production builds by default. Set to "false" to disable on Vercel.
# For local dev, set to "true" if you need to test offline / install prompts.
# ENABLE_PWA=true

# Optional: public URL for invite/SMS links when dev is localhost but links open on phones.
# In production, always use https:// (public CA). Example: https://your-domain.com — no trailing slash.
# PUBLIC_APP_URL="https://your-production-domain.com"

# Optional: beta self-signup — openssl rand -hex 32
# Share: {your-app-url}/join/{BETA_JOIN_SECRET}
# BETA_JOIN_SECRET=""

# Flight lookup — https://aviationstack.com/signup/free
AVIATIONSTACK_ACCESS_KEY=""

# Optional: download Stitch screen HTML + PNG into design/stitch/ (see docs/STITCH_UI.md)
# STITCH_API_KEY=""
